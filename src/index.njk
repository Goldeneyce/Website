{% include "components/partners.njk" %}

<section class="section-padding" aria-labelledby="insights-title">
  <div class="container">
    <p class="eyebrow">Practical guidance</p>
    <h2 class="section-title" id="insights-title">Latest Insights</h2>
    {% if posts.length %}
      <div class="blog-grid">
        {% for post in posts %}
          {% if loop.index <= 3 %}
          <article class="blog-card">
            {% if post.imageUrl %}<a class="blog-card-image" href="/blog/{{ post.slug }}/"><img src="{{ post.imageUrl }}" alt="{{ post.imageAlt or post.title }}" loading="lazy"></a>{% endif %}
            <div class="blog-card-content">
              <p class="blog-meta"><span>{{ post.category or "Elevator insights" }}</span><time datetime="{{ post.publishedAt }}">{{ post.publishedAt | readableDate }}</time></p>
              <h3><a href="/blog/{{ post.slug }}/">{{ post.title }}</a></h3>
              <p>{{ post.excerpt }}</p>
              <a class="text-link" href="/blog/{{ post.slug }}/">Read article</a>
            </div>
          </article>
          {% endif %}
        {% endfor %}
      </div>
    {% else %}
      <div class="empty-state"><p>Our practical elevator guides and maintenance insights are coming soon.</p><a href="/blog/" class="text-link">Visit the blog</a></div>
    {% endif %}
  </div>
</section>

{% include "components/cta.njk" %}
